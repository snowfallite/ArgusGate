POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=argusgate
POSTGRES_USER=argus
POSTGRES_PASSWORD=changeme_secure

REDIS_URL=redis://redis:6379/0

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=attack_signatures

CLIENT_API_KEY=arg_live_changethis_32chars_minimum
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_secure

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Any random string, keep secret
JWT_SECRET=change-me-in-production-jwt-secret

TORCH_INDEX=https://download.pytorch.org/whl/cu121
PROVIDER_BASE_URL=https://api.openai.com/v1
PROVIDER_API_KEY=sk-changeme

JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o-mini
JUDGE_API_KEY=sk-changeme

ML_THRESHOLD_PASS=0.4
ML_THRESHOLD_BLOCK=0.85
VECTOR_SIMILARITY_THRESHOLD=0.92
SESSION_RISK_THRESHOLD=0.75
SESSION_TTL_SECONDS=1800

LAYER7_ENABLED=true

# HuggingFace token — нужен только для первоначальной загрузки моделей в volume.
# Создать на https://huggingface.co/settings/tokens (read-only достаточно).
# После docker compose --profile setup run --rm model-downloader можно оставить пустым.
HF_TOKEN=
